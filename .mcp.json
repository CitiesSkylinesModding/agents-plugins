{
  "mcpServers": {
    "gameface": {
      "command": "${GAMEFACE_MCP_RUNTIME:-node}",
      "args": ["plugins/coherent-gameface/mcp/dist/server.mjs"],
      "env": {
        "GAMEFACE_HOST": "${GAMEFACE_HOST:-localhost}",
        "GAMEFACE_PORT": "${GAMEFACE_PORT:-9444}"
      }
    },
    "unity": {
      "command": "plugins/unity-devtools/mcp/dist/unity-devtools-mcp.exe"
    }
  }
}
