{
  "mcpServers": {
    "gameface": {
      "command": "${GAMEFACE_MCP_RUNTIME:-node}",
      "args": ["plugins/coherent-gameface/mcp/dist/server.mjs"],
      "env": {
        "GAMEFACE_HOST": "${GAMEFACE_HOST:-localhost}",
        "GAMEFACE_PORT": "${GAMEFACE_PORT:-9444}"
      }
    },
    "unity": {
      "command": "dotnet",
      "args": [
        "run",
        "-v",
        "q",
        "--project",
        "plugins/unity-devtools/mcp/UnityDevtools.Mcp.csproj",
        "--property:BaseOutputPath=bin/mcp-run/"
      ],
      "env": {
        "UNITY_MCP_HOST": "${UNITY_MCP_HOST:-}",
        "UNITY_MCP_PORT": "${UNITY_MCP_PORT:-}",
        "UNITY_MCP_PROCESS": "${UNITY_MCP_PROCESS:-}"
      }
    }
  }
}
