<Project Sdk="Microsoft.NET.Sdk">
  <!--
    The unity-devtools MCP server: a C# stdio MCP server that drives a running dev-Mono Unity game
    over SDB (discovery, type reflection, method invokes, ECS query/read/write, buffer edits)
    through one persistent lazy-attach session. It references the UnityDevtools.Sdb library for all
    vendored/SDB plumbing, so this project stays nullable-clean with warnings as errors.
  -->
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <!-- x-release-please-start-version -->
    <Version>0.2.0</Version>
    <!-- x-release-please-end -->
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <!-- Code-style + CA analysis gate the build; see root .editorconfig. -->
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
    <AnalysisMode>Recommended</AnalysisMode>
    <AssemblyName>unity-devtools-mcp</AssemblyName>
    <RootNamespace>UnityDevtools.Mcp</RootNamespace>
  </PropertyGroup>

  <PropertyGroup>
    <!--
      Shipped as a NuGet dotnet tool, launched by the plugin configs through
      `dotnet dnx CitiesSkylinesModding.UnityDevtools.Mcp` (version-pinned, auto-confirmed; users
      need the .NET 10 SDK).
      Publishing is manual: `mise build:unity:pack` then `mise publish:unity:nuget`.
    -->
    <PackAsTool>true</PackAsTool>
    <PackageId>CitiesSkylinesModding.UnityDevtools.Mcp</PackageId>
    <ToolCommandName>unity-devtools-mcp</ToolCommandName>
    <Authors>Morgan Touverey Quilling</Authors>
    <Description>MCP server driving a running Unity Mono development build over the Mono Soft Debugger protocol: process discovery, live type reflection, C# expression evaluation, and ECS entity/component/buffer read-write. Part of the unity-devtools agent plugin.</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/CitiesSkylinesModding/agents-plugins</PackageProjectUrl>
    <RepositoryUrl>https://github.com/CitiesSkylinesModding/agents-plugins</RepositoryUrl>
    <PackageTags>unity;mono;soft-debugger;sdb;ecs;unity-entities;game-modding;debugger;mcp</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <None Include="../README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../sdb/UnityDevtools.Sdb.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="ModelContextProtocol" Version="1.4.1" />
    <!-- Provides Host.CreateApplicationBuilder; the MCP metapackage only ships Hosting.Abstractions. -->
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.0" />
  </ItemGroup>
</Project>
