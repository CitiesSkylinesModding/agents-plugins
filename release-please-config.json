{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "separate-pull-requests": false,
  "packages": {
    "plugins/coherent-gameface": {
      "release-type": "node",
      "component": "coherent-gameface",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": false,
      "extra-files": [
        {
          "type": "json",
          "path": ".claude-plugin/plugin.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": ".codex-plugin/plugin.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "/package.json",
          "jsonpath": "$.version"
        }
      ]
    },
    "plugins/coherent-gameface/mcp": {
      "release-type": "node",
      "component": "gameface-devtools-mcp",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": false
    },
    "plugins/unity-devtools": {
      "release-type": "node",
      "component": "unity-devtools",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": false,
      "extra-files": [
        {
          "type": "json",
          "path": ".claude-plugin/plugin.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": ".codex-plugin/plugin.json",
          "jsonpath": "$.version"
        }
      ]
    },
    "plugins/unity-devtools/mcp": {
      "release-type": "node",
      "component": "unity-devtools-mcp",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": false,
      "extra-files": [
        {
          "type": "generic",
          "path": "UnityDevtools.Mcp.csproj"
        },
        {
          "type": "json",
          "path": "/plugins/unity-devtools/.mcp.json",
          "jsonpath": "$.mcpServers.unity.args[3]"
        },
        {
          "type": "json",
          "path": "/plugins/unity-devtools/.codex-plugin/mcp.json",
          "jsonpath": "$.mcpServers.unity.args[3]"
        }
      ]
    }
  },
  "plugins": [
    {
      "type": "linked-versions",
      "groupName": "coherent-gameface",
      "components": ["coherent-gameface", "gameface-devtools-mcp"]
    },
    {
      "type": "linked-versions",
      "groupName": "unity-devtools",
      "components": ["unity-devtools", "unity-devtools-mcp"]
    }
  ]
}
