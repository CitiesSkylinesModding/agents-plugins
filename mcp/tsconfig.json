{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../tsconfig.json",
  "compilerOptions": {
    // The page-context functions injected via Runtime.evaluate need browser DOM types.
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["node"]
  },
  // The root config's include resolves relative to the root; scope this project to the sources.
  "include": ["src"]
}
